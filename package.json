{
  "name": "vueai-chat",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "main": "dist_electron/main.js",
  "scripts": {
    "dev": "vite",
    "server": "tsx server.ts",
    "dev:all": "concurrently \"npm run server\" \"npm run dev\"",
    "build": "vue-tsc -b && vite build",
    "preview": "vite preview",
    "electron": "NODE_ENV=development electron .",
    "electron-dev": "concurrently \"npm run server\" \"npm run vite\" \"wait-on http://localhost:5173 && npm run electron\"",
    "electron-build": "npm run build && electron-builder"
  },
  "dependencies": {
    "@google/generative-ai": "^0.24.1",
    "cors": "^2.8.6",
    "dotenv": "^17.4.2",
    "express": "^5.2.1",
    "openai": "^6.34.0",
    "vue": "^3.5.32"
  },
  "devDependencies": {
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/node": "^24.12.2",
    "@vitejs/plugin-vue": "^6.0.5",
    "@vue/tsconfig": "^0.9.1",
    "concurrently": "^9.2.1",
    "electron": "^41.2.0",
    "electron-builder": "^26.8.1",
    "esbuild": "^0.28.0",
    "tsx": "^4.21.0",
    "typescript": "~6.0.2",
    "vite": "^8.0.4",
    "vue-tsc": "^3.2.6"
  }
}
